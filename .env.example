# =========================================================================
# Environment Variables Example Configuration
# Copy this file to '.env' and fill in your local and provider secrets.
# =========================================================================

# Database Configuration (PostgreSQL database url)
DATABASE_URL="postgresql://username:password@localhost:5432/ecommerce_db?schema=public"

# Next Auth Configuration
# NEXTAUTH_URL should point to your local development server base url.
NEXTAUTH_URL="http://localhost:3000"
# NEXTAUTH_SECRET is a random string used to sign JWTs. Generate one via: openssl rand -base64 32
NEXTAUTH_SECRET="your_nextauth_jwt_signing_secret_here"

# Google OAuth API Keys
# Obtain these from the Google Cloud Console (APIs & Services > Credentials)
GOOGLE_CLIENT_ID="your_google_client_id_here.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-your_google_client_secret_here"

# SMTP Email Server Settings
# Used for sending registration and verification notifications to sellers.
EMAIL_SERVER_USER="your_smtp_username_here"
EMAIL_SERVER_PASSWORD="your_smtp_password_here"
EMAIL_FROM="no-reply@yourdomain.com"

# Cloudinary Configuration
# Obtained from your Cloudinary console dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name_here"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your_cloudinary_upload_preset_here"
CLOUDINARY_API_KEY="your_cloudinary_api_key_here"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret_here"
